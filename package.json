{
  "name": "ecommerce-dynamic-route",
  "packageManager": "npm@11.6.2",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:customer": "turbo dev --filter=customer-app",
    "dev:seller": "turbo dev --filter=seller-app",
    "dev:admin": "turbo dev --filter=admin-app",
    "build": "turbo build",
    "lint": "turbo lint",
    "start": "turbo start"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "radix-ui": "^1.4.3"
  }
}
